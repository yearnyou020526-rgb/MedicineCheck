<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_unchecked"
    android:clickable="true"
    android:focusable="true"
    android:padding="8dp">

    <ImageView
        android:id="@+id/widget_pill"
        android:layout_width="44dp"
        android:layout_height="28dp"
        android:layout_gravity="center"
        android:contentDescription="@string/pill_icon"
        android:rotation="-32"
        android:src="@drawable/pill_shape" />

    <ImageView
        android:id="@+id/widget_check"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_gravity="center"
        android:contentDescription="@string/check_icon"
        android:src="@drawable/ic_check"
        android:visibility="gone" />
</FrameLayout>
